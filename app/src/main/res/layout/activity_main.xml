<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/CL_Root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/LL_MainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="60dp">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/LL_Header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="32dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/TV_AppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="StreamVerse"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="@color/purple_primary"
                android:letterSpacing="0.02" />

            <TextView
                android:id="@+id/TV_AppSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your anime &amp; drama catalog"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Anime / Drama Tabs -->
        <LinearLayout
            android:id="@+id/LL_CategoryTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="14dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/BTN_TabAnime"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="  Anime"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginEnd="10dp"
                android:drawableStart="@android:drawable/ic_media_play"
                android:drawablePadding="4dp"
                app:backgroundTint="@color/purple_primary"
                app:strokeWidth="0dp"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/BTN_TabDrama"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="  Drama"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:drawableStart="@android:drawable/ic_menu_slideshow"
                android:drawablePadding="4dp"
                app:backgroundTint="@color/bg_card"
                app:strokeColor="@color/text_secondary"
                app:strokeWidth="1dp"
                app:cornerRadius="14dp" />

        </LinearLayout>

        <!-- Genre Chips -->
        <HorizontalScrollView
            android:id="@+id/HSV_GenreFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:id="@+id/LL_GenreChips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                    android:id="@+id/CHIP_GenreLove"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="Love"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"
                    android:checkable="false"
                    app:chipBackgroundColor="@color/purple_primary"
                    app:chipStrokeWidth="0dp"
                    app:checkedIconVisible="false"
                    app:chipCornerRadius="20dp"
                    style="@style/Widget.MaterialComponents.Chip.Action" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/CHIP_GenreAction"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="Action"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"
                    android:checkable="false"
                    app:chipBackgroundColor="@color/bg_card"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/text_secondary"
                    app:checkedIconVisible="false"
                    app:chipCornerRadius="20dp"
                    style="@style/Widget.MaterialComponents.Chip.Action" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/CHIP_GenreComedy"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="Comedy"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"
                    android:checkable="false"
                    app:chipBackgroundColor="@color/bg_card"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/text_secondary"
                    app:checkedIconVisible="false"
                    app:chipCornerRadius="20dp"
                    style="@style/Widget.MaterialComponents.Chip.Action" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Content List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/RV_ContentList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clipToPadding="false" />

    </LinearLayout>

    <!-- FAB Add Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/BTN_AddContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="76dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Add Content"
        app:backgroundTint="@color/purple_primary"
        app:tint="@color/white"
        app:fabSize="normal"
        app:borderWidth="0dp" />

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/BNV_BottomNav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:background="@color/bg_nav"
        app:itemIconTint="@color/purple_primary"
        app:itemTextColor="@color/purple_primary"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>