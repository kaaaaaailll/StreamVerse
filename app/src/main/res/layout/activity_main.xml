<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/CL_Root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d0d1a"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/LL_MainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="80dp">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/LL_Header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="36dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/TV_AppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="StreamVerse"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#c084fc"
                android:letterSpacing="0.02" />

            <TextView
                android:id="@+id/TV_AppSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My anime &amp; drama catalog"
                android:textSize="13sp"
                android:textColor="#7a7a9a"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Anime / Drama Tabs -->
        <LinearLayout
            android:id="@+id/LL_CategoryTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/BTN_TabAnime"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Anime"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginEnd="10dp"
                app:icon="@drawable/ic_anime"
                app:iconTint="@color/white"
                app:iconPadding="6dp"
                app:iconGravity="textStart"
                app:backgroundTint="#9B59B6"
                app:strokeWidth="0dp"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/BTN_TabDrama"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Drama"
                android:textColor="#7a7a9a"
                android:textSize="15sp"
                android:textStyle="bold"
                app:icon="@drawable/ic_drama"
                app:iconTint="#7a7a9a"
                app:iconPadding="6dp"
                app:iconGravity="textStart"
                app:backgroundTint="#1a1a2e"
                app:strokeColor="#2e2e50"
                app:strokeWidth="1dp"
                app:cornerRadius="14dp" />

        </LinearLayout>

        <!-- Genre Chips -->
        <HorizontalScrollView
            android:id="@+id/HSV_GenreFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:id="@+id/LL_GenreChips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                    android:id="@+id/CHIP_GenreLove"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Love"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    android:checkable="false"
                    app:chipBackgroundColor="#9B59B6"
                    app:chipStrokeWidth="0dp"
                    app:checkedIconVisible="false"
                    app:chipCornerRadius="18dp"
                    style="@style/Widget.MaterialComponents.Chip.Action" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/CHIP_GenreAction"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Action"
                    android:textColor="#7a7a9a"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"
                    android:checkable="false"
                    app:chipBackgroundColor="#1a1a2e"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="#2e2e50"
                    app:checkedIconVisible="false"
                    app:chipCornerRadius="18dp"
                    style="@style/Widget.MaterialComponents.Chip.Action" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/CHIP_GenreComedy"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Comedy"
                    android:textColor="#7a7a9a"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"
                    android:checkable="false"
                    app:chipBackgroundColor="#1a1a2e"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="#2e2e50"
                    app:checkedIconVisible="false"
                    app:chipCornerRadius="18dp"
                    style="@style/Widget.MaterialComponents.Chip.Action" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/LL_EmptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:alpha="0.2"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nothing here yet"
                android:textColor="#7a7a9a"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap + to add your first title"
                android:textColor="#4a4a6a"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Content List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/RV_ContentList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:clipToPadding="false" />

    </LinearLayout>

    <!-- FAB Add Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/BTN_AddContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="80dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Add Content"
        app:backgroundTint="#c084fc"
        app:tint="@color/white"
        app:fabSize="normal"
        app:borderWidth="0dp"
        app:elevation="12dp"
        app:hoveredFocusedTranslationZ="6dp" />

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/BNV_BottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#0d0d1a"
        android:paddingBottom="8dp"
        app:itemIconTint="#c084fc"
        app:itemTextColor="#c084fc"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>